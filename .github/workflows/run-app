name: run-app

on: workflow_dispatch

jobs:
  run-java-app:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4

      - uses: actions/setup-java@v4
        with:
          distribution: temurin
          java-version: 17

      - name: Build the app
        run: mvn -B package

      - name: Run the app
        run: java -jar target/myapp.jar &
      
      - name: Test endpoint
        run: curl http://localhost:8080
